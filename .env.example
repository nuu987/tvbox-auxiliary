# TVBox Auxiliary — 环境变量模板
# 复制本文件为 .env 后修改：cp .env.example .env
# 至少必须修改 ADMIN_TOKEN 为强密码

# ─── 必需 ────────
# 管理后台 Bearer 令牌，必须修改为强密码（scripts/start.js 以 changeme 为标记自动初始化 .env）
ADMIN_TOKEN=changeme

# ─── 常用可选 ────────
# 服务监听端口，默认 5678（scripts/start.js 以 5678 为标记自动初始化 .env）
PORT=5678
# 数据目录，默认项目根 data/；Docker 中由 Dockerfile 设为 /app/data
DATA_DIR=./data
# 服务对外可达地址如 http://192.168.1.100:5678，Docker 部署建议填写；留空则自动检测局域网 IP
BASE_URL=
# 自动聚合 cron 表达式，留空禁用；有效格式如 "0 5 * * *" 每天 5 点；环境变量优先于网页配置
CRON_SCHEDULE=0 5 * * *
# true/1/yes/on 开启 debug 日志，默认 false 仅 info/warn/error/security
VERBOSE=false
# 日志时间戳时区，默认跟随系统
TZ=Asia/Shanghai
# 设为 0 时关闭局域网主机校验，允许任意 host 智能响应——仅开发调试用，生产勿设 0
DMZ=

# ─── 超时调优（毫秒，均有代码默认值，一般无须修改）────
# 配置 URL 测速超时（config.ts DEFAULT_SPEED_TIMEOUT_MS）
SPEED_TIMEOUT_MS=5000
# 站点 API 超时（config.ts DEFAULT_SITE_TIMEOUT_MS）
SITE_TIMEOUT_MS=3000
# fetch 配置 JSON 超时（config.ts DEFAULT_FETCH_TIMEOUT_MS，30s，部分源响应较慢）
FETCH_TIMEOUT_MS=30000
# 独立刷新接口令牌，一般留空
REFRESH_TOKEN=

# ─── 自动抓取（开发调试，非专业用户勿启用）────
SCRAPE_SOURCE_URL=
SCRAPE_SOURCE_REFERER=
MACCMS_API_URL=
MACCMS_AES_KEY=
MACCMS_AES_IV=
